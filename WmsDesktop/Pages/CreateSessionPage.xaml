<Page x:Class="WmsDesktop.Pages.CreateSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:WmsDesktop"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateSessionPage">
    <Page.Resources>

        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <local:CatalogToBackgroundColorConverter x:Key="CatalogToBackgroundColorConverter"/>

        <DataTemplate DataType="{x:Type local:IncomeItemVm}">
            <Border
                Margin="0 0 5 0"
                BorderBrush="#efefef"
                BorderThickness="2">
                <Grid 
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    MouseDown="Grid_MouseDown"
                    
                    >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Padding="5"
                        Grid.Column="0"
                        Text="{Binding Sku}"
                        ></TextBlock>
                    <TextBlock 
                         Padding="5"
                         Grid.Column="1"
                         Text="{Binding TE}"
                         ></TextBlock>
                    <TextBlock 
                        Padding="5"
                        Grid.Column="2"
                        Text="{Binding Name}"
                        ></TextBlock>
                    <TextBlock 
                        Padding="5"
                        Grid.Column="4"
                        HorizontalAlignment="Center"
                        Text="{Binding Count}"></TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:SelectedIncomeItemVm}">
            <Border
         Margin="0 0 5 0"
         BorderBrush="#efefef"
         BorderThickness="2">
                <Grid 
             Grid.Row="0"
             Grid.Column="0"
             Grid.ColumnSpan="2"
             Background="#FF3131"
             MouseDown="Grid_MouseDown"
             
             >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                 Padding="5"
                 Grid.Column="1"
                 Text="{Binding Sku}"
                 ></TextBlock>
                    <TextBox 
                  Padding="5"
                  Grid.Column="2"
                  Text="{Binding TE}"
                  ></TextBox>
                    <TextBlock 
                 Padding="5"
                 Grid.Column="3"
                 Text="{Binding Name}"
                 ></TextBlock>
                    <Button
                Grid.Column="4"
                Content="delete"
                Width="100"
                Command="{Binding DataContext.removeLine,
                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"></Button>
                    <TextBlock 
                 Padding="5"
                 Grid.Column="5"
                 HorizontalAlignment="Center"
                 Text="{Binding Count}"></TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:IncomeItemWithDateVm}">
            <Border
                Margin="0 0 5 0"
                BorderBrush="#efefef"
                BorderThickness="2">
                <Grid 
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                    Padding="5"
                    Grid.Column="0"
                    Text="{Binding Sku}"
                    ></TextBlock>
                    <TextBlock 
                    KeyDown="TextBox_KeyDown_1"
                    Padding="5"
                    Grid.Column="1"
                    Text="{Binding TE}"></TextBlock>
                    <TextBlock 
                    Padding="5"
                    Grid.Column="2"
                    Text="{Binding Name}"></TextBlock>
                    <DatePicker 
                    MaxHeight="35"
                    Grid.Row="0"
                    SelectedDate="{Binding Date, Mode=TwoWay}"
                    IsEnabled="False"
                    Grid.Column="3"
                    Margin="15 10 15 10"/>
                    <TextBlock
                    Loaded="TextBox_Loaded"
                    KeyDown="TextBox_KeyDown"
                    Padding="5"
                    Grid.Column="4"
                    HorizontalAlignment="Center"
                    Text="{Binding Count}"></TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:SelectedIncomeItemWithDateVm}">
            <Grid 
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#FF3131"
                
                >

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Padding="5"
                    Grid.Column="0"
                    Text="{Binding Sku}"
                    ></TextBlock>
                <TextBox 
                      KeyDown="TextBox_KeyDown_1"
                      Padding="5"
                      Grid.Column="1"
                      Text="{Binding TE}"
                    ></TextBox>
                <TextBlock 
                    Padding="5"
                    Grid.Column="2"
                    Text="{Binding Name}"></TextBlock>
                <DatePicker 
                    MaxHeight="35"
                    Grid.Row="0"
                    SelectedDate="{Binding Date, Mode=TwoWay}"
                    IsEnabled="True"
                    Grid.Column="3"
                    Margin="15 10 15 10"/>
                <Button
                    Grid.Column="4"
                    Content="delete"
                    Width="100"
                    Command="{Binding DataContext.removeLine,
                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"></Button>
                <TextBox
                    Loaded="TextBox_Loaded"
                    KeyDown="TextBox_KeyDown"
                    Padding="5"
                    Grid.Column="5"
                    HorizontalAlignment="Center"
                    Text="{Binding Count}"></TextBox>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:IncomeItemWithBatchVm}">
            <Border
                Margin="0 0 5 0"
                BorderBrush="#efefef"
                BorderThickness="2">
                <Grid 
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                MouseDown="Grid_MouseDown_1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                    Padding="5"
                    Grid.Column="0"
                    Text="{Binding Sku}"

                    ></TextBlock>
                    <TextBlock 
                     Padding="5"
                     Grid.Column="1"
                     Text="{Binding Sku}"

                     ></TextBlock>
                    <TextBlock 
                    Padding="5"
                    Grid.Column="2"
                    Text="{Binding Name}"></TextBlock>
                    <TextBlock 
                      Padding="5"
                      Grid.Column="3"
                      Text="{Binding Batches}"
                      ></TextBlock>
                    <TextBlock
                    Padding="5"
                    Grid.Column="4"
                    HorizontalAlignment="Center"
                    Text="{Binding Count}"></TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:SelectedIncomeItemWithBatchVM}">
            <Grid 
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#FF3131"
                MouseDown="Grid_MouseDown_1"
                >

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Padding="5"
                    Grid.Column="0"
                    Text="{Binding Sku}"
                    ></TextBlock>
                <TextBlock 
                    Padding="5"
                    Grid.Column="1"
                    Text="{Binding Name}"></TextBlock>
                <TextBox 
                      Padding="5"
                      Grid.Column="2"
                      Text="{Binding Batches}"
                      ></TextBox>
                <Button
                     Grid.Column="3"
                     Content="delete"
                     Width="100"
                     Command="{Binding DataContext.removeLine,
                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"></Button>
                <TextBlock
                    Padding="5"
                    Grid.Column="4"
                    HorizontalAlignment="Center"
                    Text="{Binding Count}"></TextBlock>
            </Grid>
        </DataTemplate>
    </Page.Resources>





    <Grid Visibility="Visible" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" >

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Visibility="Visible" 
                          Grid.Row="1" 
                          Background="White"
                          Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.4*"/>
                <RowDefinition Height="0.6*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*"/>
                <ColumnDefinition Width="0.65*"/>
            </Grid.ColumnDefinitions>
            <!--Left Top-->
            <StackPanel 
                Grid.Row="0"
                Grid.Column="0">

                <Grid 
                        Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>



                </Grid>




                <!--Client-->
                <Grid 
                    Grid.Row="0"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Клиент"></TextBlock>
                    <ComboBox
                        MaxHeight="40"
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="15 10 15 10"/>
                </Grid>
                <!--Cell-->
                <Grid 
                    Grid.Row="1"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Ячейка"></TextBlock>
                    <ComboBox
                        MaxHeight="40"
                        ItemsSource="{Binding Cells}"
                        SelectedItem="{Binding SelectedCell, Mode=TwoWay}"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="15 10 15 10" SelectionChanged="ComboBox_SelectionChanged"/>
                </Grid>
                <!--Cell-->
                <Grid 
                    Grid.Row="2"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Дата прихода"></TextBlock>
                    <DatePicker 
                        MaxHeight="35"
                        Grid.Row="0"
                        SelectedDate="{Binding Date, Mode=TwoWay}"
                        Grid.Column="1"
                        Margin="15 10 15 10"/>
                </Grid>


            </StackPanel>
            <!--Right Top-->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.2*"/>
                    <RowDefinition Height="0.8*"/>
                </Grid.RowDefinitions>
                <StackPanel 
                    Grid.Row="0" 
                    Orientation="Horizontal"
                    Height="40">
                    
                    <TextBox x:Name="textBoxSearhc" Text="{Binding TbText, UpdateSourceTrigger=PropertyChanged}"  
                    Padding="5"
                    Margin="5"
                    MinWidth="125"></TextBox>
                    <Button 
                        IsEnabled="{Binding IsSupplierSelected}"
                        Command="{Binding loadFile}"
                        Width="150"
                        Height="30">Загрузить из файла</Button>
                </StackPanel>

                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding CatalogItems}"
                    DisplayMemberPath="Name"
                    SelectedItem="{Binding SelectedCatalogItem, Mode=OneWayToSource}"
                    Margin="0 0 10 20"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" 
                    x:Name="listItems"
                    SelectionChanged="listItems_SelectionChanged">

                </ListBox>
            </Grid>
            <!--Down-->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.8*"/>
                    <RowDefinition Height="0.2*"/>
                </Grid.RowDefinitions>
                <ScrollViewer 
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalScrollBarVisibility="Auto"
                    x:Name="SWCreatingAssembly" 
                    Visibility="Visible">

                    <ItemsControl 
                                Grid.Row="0" 
                                ItemsSource="{Binding Items}"
                                Margin="0,0,0,58" 
                                >

                    </ItemsControl>
                    

                </ScrollViewer>
                <StackPanel 
                    Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left" 
                    Margin="192,0,0,0">
                    <Button 
                        Command="{Binding createSession}" 
                        Padding="10" 
                        Margin="10"
                        IsEnabled="{Binding IsSupplierSelected}">Создать</Button>
                    <Button 
                        Command="{Binding clearItems}" 
                        Padding="10" 
                        Margin="10"
                        IsEnabled="{Binding IsSupplierSelected}">Отменить</Button>
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>

</Page>
