<Page x:Class="WmsDesktop.Pages.CreateSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:WmsDesktop"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateSessionPage">
    <Page.Resources>

        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <local:CatalogToBackgroundColorConverter x:Key="CatalogToBackgroundColorConverter"/>
    </Page.Resources>
    <Grid Visibility="Visible" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" >

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Visibility="Visible" 
                          Grid.Row="1" 
                          Background="AliceBlue"
                          Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.4*"/>
                <RowDefinition Height="0.6*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*"/>
                <ColumnDefinition Width="0.65*"/>
            </Grid.ColumnDefinitions>
            <!--Left Top-->
            <Grid 
                Grid.Row="0"
                Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.25*"/>
                    <RowDefinition Height="0.25*"/>
                    <RowDefinition Height="0.25*"/>
                    <RowDefinition Height="0.25*"/>
                </Grid.RowDefinitions>
                <Grid 
                        Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>



                </Grid>
                

               
                
                <!--Client-->
                <Grid 
                    Grid.Row="0"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Клиент"></TextBlock>
                    <ComboBox
                        MaxHeight="40"
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="15 10 15 10"/>
                </Grid>
                <!--Cell-->
                <Grid 
                    Grid.Row="1"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Ячейка"></TextBlock>
                    <ComboBox
                        MaxHeight="40"
                        ItemsSource="{Binding Cells}"
                        SelectedItem="{Binding SelectedCell, Mode=TwoWay}"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="15 10 15 10" SelectionChanged="ComboBox_SelectionChanged"/>
                </Grid>
                <!--Cell-->
                <Grid 
                    Grid.Row="2"
                    Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Дата"></TextBlock>
                    <DatePicker 
                        MaxHeight="35"
                        Grid.Row="0"
                        SelectedDate="{Binding Date, Mode=TwoWay}"
                        Grid.Column="1"
                        Margin="15 10 15 10"/>
                </Grid>
                

            </Grid>
            <!--Right Top-->
            <StackPanel Grid.Column="1">

                <StackPanel Orientation="Horizontal">
                    <ComboBox
                        x:Name="CBSuppliers"
                        Width="125"
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier}"
                        DisplayMemberPath="Name"
                        Margin="5">

                    </ComboBox>
                    <TextBox x:Name="textBoxSearhc" Text="{Binding TbText, UpdateSourceTrigger=PropertyChanged}"  
                    Padding="5"
                    Margin="5"
                    MinWidth="125"></TextBox>

                </StackPanel>

                <ListBox
                    ItemsSource="{Binding ItemsList}"
                    SelectedItem="{Binding SelectedItem, Mode=OneWayToSource}"
                    Margin="0 0 10 0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                        x:Name="listItems"
                                        >

                </ListBox>
            </StackPanel>
            <!--Down-->
            <ScrollViewer 
                Grid.Row="1"
                Grid.ColumnSpan="2"
                x:Name="SWCreatingAssembly" 
                Visibility="Visible">
                <StackPanel>

                    <Grid  >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="99*"/>
                            <ColumnDefinition Width="664*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding Items}" Grid.ColumnSpan="2" Margin="0,0,0,58" Grid.RowSpan="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="15" >
                                        <Grid Margin="10" Background="{Binding Catalog, Converter={StaticResource CatalogToBackgroundColorConverter}}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                                    <i:InvokeCommandAction 
                                                                        Command="{Binding DataContext.callBorkDialog, 
                                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Padding="10" Text="{Binding Left}" Grid.Column="0"></TextBlock>
                                            <TextBlock Padding="10" Text="{Binding Center}" Grid.Column="1"></TextBlock>
                                            <TextBlock Padding="10" Text="{Binding Right}" Grid.Column="2" HorizontalAlignment="Right"></TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Grid.Column="1" Margin="192,0,0,0">
                            <Button Command="{Binding createSession}" Padding="10" Margin="10">Создать</Button>
                            <Button Command="{Binding clearItems}" Padding="10" Margin="10">Отменить</Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

        </Grid>

    </Grid>

</Page>
