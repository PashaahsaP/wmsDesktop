<Page x:Class="WmsDesktop.Pages.AddingCatalogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WmsDesktop"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Loaded="Page_Loaded"
      Title="AddingCatalogsPage"
      >
    <Page.Resources>
        <DataTemplate DataType="{x:Type local:CatalogItemBase}">
            <Grid  Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0" >   
                    
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.4*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="5">Имя</TextBlock>
                        <TextBox Grid.Column="1" 
                                 x:Name="TbText"  
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    </Grid>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.4*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="5">Артикул</TextBlock>
                        <TextBox Grid.Column="1" 
                                 x:Name="tbSku"  
                                 Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    </Grid>

                    <Grid  Margin="5" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.3*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="5"> ШК</TextBlock>
                        <TextBox Grid.Column="1" x:Name="tbBarcode"  Text="{Binding DataContext.TbBarcode, RelativeSource={RelativeSource AncestorType=ContentControl} }"></TextBox>
                    </Grid>
                    <Button 
                        x:Name="btnCatalogBorkAdd" 
                        Height="30" 
                        Width="120"
                        Margin="5"                
                        Command="{Binding DataContext.addBarcode, RelativeSource={RelativeSource AncestorType=ContentControl} }">Добавить шк</Button>
                    <Button 
                        x:Name="btnCatalogBoAdd" 
                        Height="30" 
                        Width="120"
                        Margin="5"
                        Command="{Binding DataContext.clearFields, RelativeSource={RelativeSource AncestorType=ContentControl} }">Очистить</Button>
                    <Button x:Name="btnCatalogBorkAd" 
                        Height="30" 
                        Width="120"
                        Margin="5"
                         IsEnabled="{Binding DataContext.IsEnabledSave, RelativeSource={RelativeSource AncestorType=ContentControl} }"
                        Command="{Binding DataContext.updateEntity, RelativeSource={RelativeSource AncestorType=ContentControl} }">Сохранить</Button>
                    <Button 
                        Height="30" 
                        Width="120"
                        Margin="5"
                        IsEnabled="{Binding DataContext.IsEnabledAppend, RelativeSource={RelativeSource AncestorType=ContentControl} }"
                        Command="{Binding DataContext.addEntity, RelativeSource={RelativeSource AncestorType=ContentControl} }">Добавить</Button>
                    <TextBlock x:Name="tbError" 
               Text="{Binding TblockError, UpdateSourceTrigger=PropertyChanged}"
               ></TextBlock>
                </StackPanel>

                <ItemsControl
                    
                    Grid.Column="1"
                    ItemsSource="{Binding DataContext.SelectedBarcodes, RelativeSource={RelativeSource AncestorType=ContentControl} }"
                    HorizontalContentAlignment="Stretch">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border 
                        Background="#2596be"
                        CornerRadius="5"
                        Padding="3"
                        Margin="5">
                                <Grid 
                        VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="0.2*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock 
                            Grid.Column="0"
                            Foreground="White"
                            FontFamily="Cascadia Mono"
                            Padding="2"
                            Margin="0"
                            Text="{Binding Name}"
                            ></TextBlock>
                                    <Button 
                            Background="Transparent" 
                            Grid.Column="1"
                            Foreground="White"
                            Padding="0"
                            Margin="0"
                            Command="{Binding DataContext.removeBarcode, 
              RelativeSource={RelativeSource AncestorType={x:Type ContentControl}}}"
                            CommandParameter="{Binding}"
                            >X</Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>
      
    </Page.Resources>
    <Grid Background="White">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid  >
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="0.7*"/>
                </Grid.ColumnDefinitions>
                <ComboBox
                    Name="CBSuppliersCatalog"
                    Grid.Row="0"
                    Grid.Column="0"
                    Height="30"
                    Width="100"
                    ItemsSource="{Binding MainSuppliers}"
                    SelectedItem="{Binding MainSelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    >
                    
                </ComboBox>
                <ContentControl
                    Content="{Binding SelectedCatalogItem, UpdateSourceTrigger=PropertyChanged}"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Grid.Row="1">
                </ContentControl>
            </Grid>
            <StackPanel Grid.Column="1">

                <StackPanel Orientation="Horizontal">
                    <ComboBox
                        x:Name="CBSuppliers"
                        Width="125"
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier}"
                        DisplayMemberPath="Name"
                        Margin="5">

                    </ComboBox>
                    <TextBox x:Name="textBoxSearhc" Text="{Binding TbText, UpdateSourceTrigger=PropertyChanged}"  
                    Padding="5"
                    Margin="5"
                    MinWidth="125"></TextBox>

                </StackPanel>

                <ListBox
                    ItemsSource="{Binding ItemsList}"
                    SelectedItem="{Binding SelectedItem, Mode=OneWayToSource}"
                    Margin="0 0 10 0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                        x:Name="listItems"
                                        SelectionChanged="listItems_SelectionChanged">

                </ListBox>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
